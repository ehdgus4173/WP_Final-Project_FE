# =====================================================
# What's Today · Frontend Environment Variables
# =====================================================
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# ─── Backend API ─────────────────────────────────────
# The base URL for all REST API requests.
# Local backend development: http://localhost:3000/api
# Production:                 https://wp-final-projcet-be.onrender.com/api
VITE_API_URL=https://wp-final-projcet-be.onrender.com/api

# ─── Supabase OAuth ──────────────────────────────────
# Required for Google / GitHub social login.
# Get these from Supabase Dashboard → Settings → API
#
# Notes:
# - The anon (public) key is safe to expose in client code.
#   It can only do what your Row Level Security (RLS) policies allow.
# - Never put the service_role key here — that stays server-side only.
# - If these are empty, email/password login still works,
#   but the Google / GitHub buttons on login.html will fail.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here